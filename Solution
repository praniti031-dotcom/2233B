#include <bits/stdc++.h>
using namespace std;
int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int T;
    cin >> T;
    while (T--) {
        int n;
        cin >> n;
        vector<int> ans;
        for (int i = 1; i <= n; i++) ans.push_back(i);
        for (int i = 1; i <= n; i++) ans.push_back(i);
        for (int i = 1; i <= n; i++) ans.push_back(i % n + 1);
        for (int i = 1; i <= n; i++) ans.push_back(i);
        for (int x : ans) cout << x << ' ';
        cout << '\n';
    }
    return 0;
}
